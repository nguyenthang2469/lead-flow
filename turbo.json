{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/**/src/**",
        "apps/**/eslint.config.*",
        "packages/**/eslint.config.*",
        "packages/eslint-config/**",
        "package.json",
        "pnpm-lock.yaml"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
